Start-Sleep -Seconds 1
Write-Host "[*] DMA controller engaged. Scanning system memory..." -ForegroundColor Green
Write-Host ""

$hackNames = @(
    "mem_dump_analyzer",
    "kernel_patch_guard_bypass",
    "ring0_injector",
    "acpi_table_hook",
    "smram_escalation",
    "tpm_nvram_extract",
    "pci_config_read",
    "io_port_monitor",
    "msr_write_exploit",
    "dma_arbiter_overflow",
    "gpu_vram_dump",
    "cpuid_forge",
    "efi_runtime_hijack",
    "smm_callout_injection",
    "hypervisor_escape_00",
    "firmware_rop_chain",
    "vt_d_remap_bypass",
    "shadow_table_poison",
    "pcie_cfg_space",
    "chipset_scratch_write"
)

foreach ($hack in $hackNames) {
    Write-Host "[>] Scanning: $hack" -NoNewline -ForegroundColor Cyan
